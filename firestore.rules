rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function adminDocValid(id) {
      return id != null
        && exists(/databases/$(database)/documents/admin/$(id))
        && get(/databases/$(database)/documents/admin/$(id)).data.isActive != false
        && (
          get(/databases/$(database)/documents/admin/$(id)).data.isAdmin == true ||
          get(/databases/$(database)/documents/admin/$(id)).data.role == 'admin' ||
          get(/databases/$(database)/documents/admin/$(id)).data.role == 'superadmin'
        );
    }

    function isAdmin() {
      return signedIn() && (
        adminDocValid(request.auth.uid) ||
        (request.auth.token.email != null && adminDocValid(request.auth.token.email))
      );
    }

    function validSlug(value) {
      return value is string && value.matches('^[a-z0-9]+(?:-[a-z0-9]+)*$');
    }

    function validHttpUrl(value) {
      return value is string && value.matches('^https?://.+');
    }

    function validUrlOrPlaceholder(value) {
      return value is string && (
        value == '' ||
        value == '#' ||
        value.matches('^https?://.+') ||
        value.matches('^data:.+')
      );
    }

    function validShortText(value, maxLen) {
      return value is string && value.size() > 0 && value.size() <= maxLen;
    }

    function validLongText(value, maxLen) {
      return value is string && value.size() <= maxLen;
    }

    function validEmail(value) {
      return value is string && value.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$');
    }

    match /admin/{adminId} {
      allow read: if signedIn() && (request.auth.uid == adminId || request.auth.token.email == adminId || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /siteSettings/{docId} {
      allow read: if true;
      allow create, update, delete: if signedIn() && docId == 'main';
    }

    match /socialLinks/{docId} {
      allow read: if resource.data.isVisible == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /projects/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin()
        && validShortText(request.resource.data.title, 120)
        && validShortText(request.resource.data.category, 80)
        && validLongText(request.resource.data.description, 5000)
        && validUrlOrPlaceholder(request.resource.data.coverImage)
        && validUrlOrPlaceholder(request.resource.data.liveLink)
        && validUrlOrPlaceholder(request.resource.data.sourceLink);
    }

    match /services/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin()
        && validShortText(request.resource.data.title, 120)
        && validLongText(request.resource.data.description, 5000)
        && request.resource.data.icon is string
        && request.resource.data.icon.size() > 0;
    }

    match /blogPosts/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin()
        && validShortText(request.resource.data.title, 160)
        && validSlug(request.resource.data.slug)
        && validShortText(request.resource.data.excerpt, 500)
        && validLongText(request.resource.data.content, 200000)
        && (
          !('coverImage' in request.resource.data) ||
          request.resource.data.coverImage == null ||
          validUrlOrPlaceholder(request.resource.data.coverImage)
        );
    }

    match /contactMessages/{docId} {
      allow create: if request.auth == null
        && validShortText(request.resource.data.name, 120)
        && validEmail(request.resource.data.email)
        && validLongText(request.resource.data.message, 5000);
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
